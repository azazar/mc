{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build Midnight Commander (bootstrap+configure+make)",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "(test -x configure || (./autogen.sh && ./configure)) && make -j\"$(nproc)\""
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$gcc"
      ]
    }
  ]
}
